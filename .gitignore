# ---------------------------------------------------------------------------
# Bank statements & exports — NEVER commit real financial data.
# Keep test PDFs/spreadsheets out of git so a statement can't leak by accident.
# (If you ever need to commit a sample, force-add it: `git add -f sample.pdf`.)
# ---------------------------------------------------------------------------
*.pdf
*.xlsx
*.xls
*.csv

# PyInstaller build artifacts
build/
dist/
*.manifest

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db
